<div
    id="servereceiveSessionPage"
    data-team-name="{{teamName}}"
    data-team-id="{{teamId}}"
    data-session-name="{{sessionName}}"
    data-session-id="{{sessionId}}">
    <div class="page-header">
        <div>
            <h1>{{title}}</h1>
            <p class="muted-text">Select the server, optionally mark a missed serve, then select the passer and pass rating.</p>
        </div>
        <a class="purple-button" href="/servereceive/{{teamName}}">Back To Team</a>
    </div>

    <section class="panel-card">
        <div class="record-flow">
            <div class="record-step">
                <h2>1. Server</h2>
                <div id="serverOptions" class="chip-grid"></div>
            </div>

            <div class="record-step">
                <div class="toggle-row">
                    <h2>2. Result</h2>
                    <label class="checkbox-label">
                        <input type="checkbox" id="missedServe" />
                        Missed serve
                    </label>
                </div>
                <div id="passerStep">
                    <h3>Passer</h3>
                    <div id="passerOptions" class="chip-grid"></div>
                    <h3>Pass rating</h3>
                    <div id="passRatingOptions" class="rating-grid"></div>
                </div>
                <div id="derivedServeRating" class="derived-rating">Serve rating: -</div>
                <button id="recordRepButton" disabled>Record Rep</button>
                <div id="recordResult" class="inline-message"></div>
            </div>
        </div>
    </section>

    <section class="panel-card">
        <div class="section-header">
            <h2>Recent Reps</h2>
            <span id="recentCount" class="pill-label"></span>
        </div>
        <div class="table-wrapper">
            <table class="custom-table" id="recentRepsTable">
                <thead>
                <tr>
                    <th>Time</th>
                    <th>Server</th>
                    <th>Passer</th>
                    <th>Missed Serve</th>
                    <th>Pass Rating</th>
                    <th>Serve Rating</th>
                </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </section>
</div>
