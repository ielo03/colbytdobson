<div id="servereceiveTeamPage" data-team-name="{{teamName}}" data-team-id="{{teamId}}">
    <div class="page-header">
        <div>
            <h1 id="manage">{{title}}</h1>
            <p class="muted-text">Manage players, sessions, and stats for {{teamName}}.</p>
        </div>
        <a class="purple-button" href="/servereceive/{{teamName}}/stats">View Stats</a>
    </div>

    <div class="servereceive-grid">
        <section class="panel-card">
            <h2>Create Session</h2>
            <form id="sessionForm" class="stack-form">
                <label for="session">Session name</label>
                <input type="text" id="session" placeholder="Enter session name" maxlength="100" />
                <button type="submit">Create Session</button>
            </form>
            <div id="sessionResult" class="inline-message"></div>
        </section>

        <section class="panel-card">
            <h2>Add Player</h2>
            <form id="addPlayerForm" class="stack-form">
                <label for="player">Player name</label>
                <input
                    type="text"
                    id="player"
                    name="player"
                    placeholder="Enter player name"
                    maxlength="100" />
                <button type="submit">Add Player</button>
            </form>
            <div id="playerResult" class="inline-message"></div>
        </section>
    </div>

    <section class="panel-card">
        <div class="section-header">
            <h2>Sessions</h2>
            <span id="sessionsCount" class="pill-label"></span>
        </div>
        <div id="sessionsList" class="action-list"></div>
    </section>

    <section class="panel-card">
        <div class="section-header">
            <h2>Players</h2>
            <span id="playersCount" class="pill-label"></span>
        </div>
        <div class="table-wrapper">
            <table class="custom-table" id="playersTable">
                <thead>
                <tr>
                    <th>Player Name</th>
                    <th>Average Pass Rating</th>
                    <th>Total Passes</th>
                    <th>Average Serve Rating</th>
                    <th>Total Serves</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </section>
</div>
